@startuml CoreEntities
skinparam style strictuml
skinparam BoxPadding 10

' =========================
' IDENTITY & ACCESS
' =========================
package "Identity & Access" {

enum Role {
    ADMIN
    VENDOR
    AUDITOR
}

enum KycStatus {
    NONE
    PENDING
    VERIFIED
    REJECTED
}

class User {
    +UUID id
    +String walletAddress
    +String email
    +Role role
    +KycStatus kycStatus
    +DateTime createdAt
    --
    +verifySignature(nonce, signature)
    +requestKYC()
    +assignRole()
}

class UserChallenge {
    +UUID id
    +String nonce
    +DateTime createdAt
    --
    +generateNonce()
    +invalidate()
}

class VerifiedNFT {
    +String tokenId
    +String serialNumber
    +DateTime issuedAt
    --
    +mint()
    +revoke()
}

User "1" -- "0..1" VerifiedNFT : owns
User "1" -- "0..*" UserChallenge : authenticates

}

' =========================
' BLOCKCHAIN INTEGRATION
' =========================
package "Blockchain Layer (Hedera)" {

class HCSLog {
    +String topicId
    +Long sequenceNumber
    +String runningHash
    +String message
    +DateTime consensusTimestamp
    --
    +verifyIntegrity()
}

class Token {
    +String tokenId
    +String name
    +String type
    --
    +mint()
    +transfer()
}

class Wallet {
    +String accountId
    +Decimal hbarBalance
    --
    +signTransaction()
}

}

' =========================
' TENDER SYSTEM
' =========================
package "Tender System" {

enum TenderStatus {
    DRAFT
    OPEN
    CLOSED
    REVEAL_PHASE
    EVALUATING
    AWARDED
    CANCELLED
}

class Tender {
    +UUID id
    +String title
    +String description
    +String criteria
    +String hcsTopicId
    +String ipfsCid
    +String ipfsHash
    +DateTime deadlineBid
    +DateTime deadlineReveal
    +TenderStatus status
    +Integer metadataVersion
    +DateTime createdAt
    --
    +createHcsTopic()
    +publishToHCS()
    +validateDeadlines()
    +closeTender()
    +startRevealPhase()
    +finalizeTender()
    +cancelTender()
}

class Attachment {
    +UUID id
    +String ipfsCid
    +String fileHash
    +String fileType
    +String encryptionKey
    +DateTime uploadedAt
    --
    +encrypt()
    +decrypt()
}

class TenderCriteria {
    +UUID id
    +String type
    +String value
    --
    +validate()
}

Tender "1" -- "0..*" Attachment : contains
Tender "1" -- "0..*" TenderCriteria : defines

}

' =========================
' BIDDING SYSTEM
' =========================
package "Bidding & Commit-Reveal" {

enum BidStatus {
    COMMITTED
    REVEALED
    INVALID
    WITHDRAWN
}

class Bid {
    +UUID id
    +String commitHash
    +Decimal revealedValue
    +String nonce
    +BidStatus status
    +DateTime committedAt
    +DateTime revealedAt
    --
    +submitCommit()
    +revealBid()
    +verifyCommitment()
    +invalidate()
}

class BidDocument {
    +UUID id
    +String ipfsCid
    +String fileHash
    +Boolean isEncrypted
    --
    +upload()
    +verifyIntegrity()
}

Bid "1" -- "0..*" BidDocument : includes

}

' =========================
' FINANCE & ESCROW
' =========================
package "Finance & Escrow" {

enum DepositStatus {
    LOCKED
    REFUNDED
    TRANSFERRED
    SLASHED
}

class EscrowDeposit {
    +UUID id
    +String transactionId
    +Decimal amount
    +String tokenId
    +DepositStatus status
    +DateTime createdAt
    --
    +lockFunds()
    +refund()
    +transferToWinner()
    +slash()
}

class PaymentSchedule {
    +UUID id
    +String scheduleId
    +String milestone
    +Decimal amount
    +String tokenId
    +DateTime dueDate
    +Boolean executed
    --
    +schedulePayment()
    +executePayment()
    +cancel()
}

}

' =========================
' RESULTS & GOVERNANCE
' =========================
package "Evaluation & Results" {

class Ranking {
    +UUID id
    +Integer position
    +Decimal score
    --
    +calculateRanking()
}

class WinnerNFT {
    +String tokenId
    +String serialNumber
    +DateTime mintedAt
    --
    +mint()
    +verifyOwnership()
}

class EvaluationReport {
    +UUID id
    +String summary
    +String justification
    --
    +generateReport()
}

}

' =========================
' AUDIT & EVENTS
' =========================
package "Audit & Transparency" {

enum EventType {
    TenderCreated
    BidSubmitted
    TenderClosed
    RevealStarted
    WinnerDeclared
    RankingPublished
    PaymentExecuted
}

class Event {
    +UUID id
    +EventType type
    +String details
    +DateTime timestamp
    --
    +logEvent()
}

}

' =========================
' RELATIONSHIPS
' =========================

User "1" -- "0..*" Tender : creates
User "1" -- "0..*" Bid : submits

Tender "1" -- "0..*" Bid : receives
Tender "1" -- "0..*" Event : generates
Tender "1" -- "0..*" HCSLog : logs
Tender "1" -- "0..*" PaymentSchedule : schedules
Tender "1" -- "0..1" WinnerNFT : awards
Tender "1" -- "0..*" Ranking : ranks

Bid "1" -- "1" User : submitted by
Bid "1" -- "0..1" EscrowDeposit : secured by
Bid "1" -- "0..1" Ranking : ranked as

EscrowDeposit "1" -- "0..*" PaymentSchedule : triggers

WinnerNFT "1" -- "1" User : owned by

Event "1" -- "1" Tender : belongs to
Event "1" -- "0..1" HCSLog : mirrored in

HCSLog "1" -- "1" Tender : linked to

@enduml
